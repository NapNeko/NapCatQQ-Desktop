# AI 更新日志生成脚本配置文件
# 复制此文件为 .env，然后填入你的 API Key
# .env 文件已被 Git 忽略，不会提交到仓库

# 必需：API Key（二选一）
OPENAI_API_KEY="sk-..."
# 或
OPENROUTER_API_KEY="sk-or-v1-..."

# 可选：API 地址（默认使用 OpenRouter）
OPENAI_API_URL="https://openrouter.ai/api/v1/chat/completions"

# 可选：模型名称（默认使用免费模型）
OPENAI_MODEL="z-ai/glm-4.5-air:free"
