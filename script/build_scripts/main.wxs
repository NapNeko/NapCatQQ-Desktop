<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
    <?ifndef ProductName ?>
        <?define ProductName = "NapCatQQ Desktop" ?>
    <?endif?>
    <?ifndef ProductExeName ?>
        <?define ProductExeName = "NapCatQQ-Desktop.exe" ?>
    <?endif?>
    <?ifndef Manufacturer ?>
        <?define Manufacturer = "Qiao" ?>
    <?endif?>
    <?ifndef ProductVersion ?>
        <?define ProductVersion = "0.0.0" ?>
    <?endif?>
    <?ifndef SourceDir ?>
        <?define SourceDir = "..\..\dist\NapCatQQ-Desktop" ?>
    <?endif?>

    <Package
        Name="$(ProductName)"
        Manufacturer="$(Manufacturer)"
        Version="$(ProductVersion)"
        UpgradeCode="5EBD6A58-1B0A-4700-B16F-7E3D7D62949D"
        Language="1033"
        Scope="perMachine"
        InstallerVersion="500">

        <SummaryInformation Description="$(ProductName)" Manufacturer="$(Manufacturer)" />
        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
        <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

        <Property Id="ARPNOMODIFY" Value="1" />
        <Property Id="REMOVE_APP_DATA" Secure="yes" />
        <Property Id="NCDATAFOLDERPATH" Secure="yes">
            <RegistrySearch Root="HKLM" Key="Software\NapCatQQ-Desktop" Name="DataDir" Type="raw" />
        </Property>

        <Icon Id="AppIcon.ico" SourceFile="script\build_scripts\icon.ico" />
        <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
        <Property Id="ARPURLINFOABOUT" Value="https://github.com/NapNeko/NapCatQQ-Desktop" />
        <util:CloseApplication
            Id="CloseRunningDesktop"
            Target="$(ProductExeName)"
            Description="NapCatQQ Desktop is running and must be closed before setup can continue."
            PromptToContinue="yes"
            CloseMessage="yes"
            ElevatedCloseMessage="yes"
            RebootPrompt="no"
            Timeout="10" />

        <StandardDirectory Id="ProgramFiles64Folder">
            <Directory Id="INSTALLFOLDER" Name="$(ProductName)" />
        </StandardDirectory>

        <StandardDirectory Id="CommonAppDataFolder">
            <Directory Id="NCDATAFOLDER" Name="$(ProductName)" />
        </StandardDirectory>

        <StandardDirectory Id="ProgramMenuFolder">
            <Directory Id="ApplicationProgramsFolder" Name="$(ProductName)" />
        </StandardDirectory>

        <StandardDirectory Id="DesktopFolder" />

        <UI>
            <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
            <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" />
            <TextStyle Id="WixUI_Font_Title" FaceName="Tahoma" Size="9" Bold="yes" />

            <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />

            <DialogRef Id="CancelDlg" />
            <DialogRef Id="ErrorDlg" />
            <DialogRef Id="ExitDialog" />
            <DialogRef Id="FatalError" />
            <DialogRef Id="FilesInUse" />
            <DialogRef Id="MaintenanceTypeDlg" />
            <DialogRef Id="MaintenanceWelcomeDlg" />
            <DialogRef Id="MsiRMFilesInUse" />
            <DialogRef Id="OutOfDiskDlg" />
            <DialogRef Id="OutOfRbDiskDlg" />
            <DialogRef Id="PrepareDlg" />
            <DialogRef Id="ProgressDlg" />
            <DialogRef Id="ResumeDlg" />
            <DialogRef Id="UserExit" />
            <DialogRef Id="VerifyReadyDlg" />
            <DialogRef Id="WaitForCostingDlg" />
            <DialogRef Id="WelcomeDlg" />

            <Publish Dialog="ExitDialog" Control="Finish" Event="EndDialog" Value="Return" Order="999" />

            <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Order="1" Condition="NOT Installed" />
            <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Order="2" Condition="Installed AND PATCH" />

            <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="1" Condition="NOT Installed" />
            <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="MaintenanceTypeDlg" Order="2" Condition="Installed AND NOT PATCH" />
            <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="3" Condition="Installed AND PATCH" />

            <Publish Dialog="MaintenanceWelcomeDlg" Control="Next" Event="NewDialog" Value="MaintenanceTypeDlg" Order="1" Condition="1" />
            <Publish Dialog="MaintenanceTypeDlg" Control="RepairButton" Event="NewDialog" Value="VerifyReadyDlg" Order="1" Condition="1" />
            <Publish Dialog="MaintenanceTypeDlg" Control="RemoveButton" Event="NewDialog" Value="RemoveDataDlg" Order="1" Condition="NCDATAFOLDERPATH" />
            <Publish Dialog="MaintenanceTypeDlg" Control="RemoveButton" Event="NewDialog" Value="VerifyReadyDlg" Order="2" Condition="NOT NCDATAFOLDERPATH" />
            <Publish Dialog="MaintenanceTypeDlg" Control="Back" Event="NewDialog" Value="MaintenanceWelcomeDlg" Order="1" Condition="1" />

            <Dialog Id="RemoveDataDlg" Width="370" Height="270" Title="[ProductName] Setup">
                <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="!(loc.VerifyReadyDlgBannerBitmap)" />
                <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
                <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

                <Control
                    Id="Title"
                    Type="Text"
                    X="15"
                    Y="15"
                    Width="320"
                    Height="15"
                    Transparent="yes"
                    NoPrefix="yes"
                    Text="Ready to remove [ProductName]" />
                <Control
                    Id="Description"
                    Type="Text"
                    X="25"
                    Y="70"
                    Width="320"
                    Height="50"
                    NoPrefix="yes"
                    Text="Choose whether to also delete runtime data stored under ProgramData before removing the application." />
                <Control
                    Id="ProgramDataPath"
                    Type="Text"
                    X="25"
                    Y="128"
                    Width="320"
                    Height="18"
                    NoPrefix="yes"
                    Text="ProgramData path: [NCDATAFOLDERPATH]" />
                <Control
                    Id="RemoveDataCheckbox"
                    Type="CheckBox"
                    X="25"
                    Y="155"
                    Width="320"
                    Height="18"
                    Property="REMOVE_APP_DATA"
                    CheckBoxValue="1"
                    Text="Also delete runtime data in ProgramData" />
                <Control Id="Back" Type="PushButton" X="156" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)">
                    <Publish Event="NewDialog" Value="MaintenanceTypeDlg" Condition="1" />
                </Control>
                <Control Id="Remove" Type="PushButton" X="212" Y="243" Width="80" Height="17" Default="yes" Text="Remove">
                    <Publish Event="Remove" Value="All" Condition="1" />
                    <Publish Event="EndDialog" Value="Return" Condition="1" />
                </Control>
                <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
                    <Publish Event="SpawnDialog" Value="CancelDlg" Condition="1" />
                </Control>
            </Dialog>

            <UIRef Id="WixUI_Common" />
        </UI>

        <Component
            Id="ApplicationShortcutComponent"
            Directory="ApplicationProgramsFolder"
            Guid="B1E6F3A7-2386-4BFE-BD0C-5F44A13E0D7A">
            <Shortcut
                Id="ApplicationStartMenuShortcut"
                Name="$(ProductName)"
                Description="$(ProductName)"
                Target="[INSTALLFOLDER]$(ProductExeName)"
                WorkingDirectory="INSTALLFOLDER" />
            <Shortcut
                Id="ApplicationDesktopShortcut"
                Directory="DesktopFolder"
                Name="$(ProductName)"
                Description="$(ProductName)"
                Target="[INSTALLFOLDER]$(ProductExeName)"
                WorkingDirectory="INSTALLFOLDER" />
            <RemoveFolder Id="RemoveApplicationProgramsFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
            <RegistryValue
                Root="HKLM"
                Key="Software\NapCatQQ-Desktop"
                Name="InstallDir"
                Type="string"
                Value="[INSTALLFOLDER]"
                KeyPath="yes" />
        </Component>

        <Component
            Id="ApplicationDataDirectoryComponent"
            Directory="NCDATAFOLDER"
            Guid="CC367065-2D44-4513-B0F6-229E4A197A7C">
            <CreateFolder>
                <util:PermissionEx User="Users" GenericAll="yes" />
            </CreateFolder>
            <util:RemoveFolderEx
                Property="NCDATAFOLDERPATH"
                On="uninstall"
                Condition="REMOVE_APP_DATA AND NCDATAFOLDERPATH" />
            <RegistryValue
                Root="HKLM"
                Key="Software\NapCatQQ-Desktop"
                Name="DataDir"
                Type="string"
                Value="[NCDATAFOLDER]"
                KeyPath="yes" />
        </Component>

        <Feature Id="MainFeature" Title="$(ProductName)" Level="1">
            <Files Include="$(SourceDir)\**" Directory="INSTALLFOLDER" />
            <ComponentRef Id="ApplicationDataDirectoryComponent" />
            <ComponentRef Id="ApplicationShortcutComponent" />
        </Feature>
    </Package>
</Wix>
